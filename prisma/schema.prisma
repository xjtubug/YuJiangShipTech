generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Product Catalog ────────────────────────────────────────
model Category {
  id          String    @id @default(uuid())
  slug        String    @unique
  nameEn      String
  nameZh      String
  nameJa      String
  nameAr      String
  image       String?
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id              String    @id @default(uuid())
  slug            String    @unique
  sku             String    @unique
  nameEn          String
  nameZh          String
  nameJa          String
  nameAr          String
  descEn          String
  descZh          String
  descJa          String
  descAr          String
  specsJson       String    @default("{}") // JSON technical specs
  priceUsd        Float     @default(0)
  moq             Int       @default(1)
  leadTimeDays    Int       @default(30)
  images          String    @default("[]") // JSON array of image URLs
  videoUrl        String?
  pdfUrl          String?
  featured        Boolean   @default(false)
  published       Boolean   @default(true)
  status          String    @default("published") // draft, published, archived
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])
  reviews         Review[]
  expertReviews   ExpertReview[]
  inquiryItems    InquiryItem[]
  pageViews       PageView[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Review {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  author      String
  company     String?
  country     String?
  rating      Int      @default(5)
  contentEn   String
  contentZh   String   @default("")
  avatar      String?
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── B2B Inquiry System ─────────────────────────────────────
model Inquiry {
  id              String        @id @default(uuid())
  inquiryNumber   String        @unique
  companyName     String
  contactName     String
  email           String
  phone           String?
  country         String?
  message         String?
  techRequirements String?
  attachmentUrl   String?
  status          String        @default("new") // new, processing, quoted, closed
  source          String?       // page URL
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  items           InquiryItem[]
  visitorId       String?
  visitor         Visitor?      @relation(fields: [visitorId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model InquiryItem {
  id          String   @id @default(uuid())
  inquiryId   String
  inquiry     Inquiry  @relation(fields: [inquiryId], references: [id])
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  productName String
  quantity    Int      @default(1)
  unit        String   @default("pcs")
  specs       String?
  createdAt   DateTime @default(now())
}

// ─── Visitor Tracking & Lead Scoring ────────────────────────
model Visitor {
  id            String      @id @default(uuid())
  ip            String
  country       String?
  region        String?
  city          String?
  userAgent     String?
  browser       String?
  os            String?
  device        String?
  language      String?
  referrer      String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  leadScore     Int         @default(0)
  isHighValue   Boolean     @default(false)
  firstVisit    DateTime    @default(now())
  lastVisit     DateTime    @default(now())
  visitCount    Int         @default(1)
  pageViews     PageView[]
  inquiries     Inquiry[]
}

model PageView {
  id          String   @id @default(uuid())
  visitorId   String
  visitor     Visitor  @relation(fields: [visitorId], references: [id])
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  path        String
  title       String?
  duration    Int      @default(0) // seconds
  createdAt   DateTime @default(now())
}

// ─── CMS Content ────────────────────────────────────────────
model News {
  id          String   @id @default(uuid())
  slug        String   @unique
  titleEn     String
  titleZh     String
  titleJa     String   @default("")
  titleAr     String   @default("")
  contentEn   String
  contentZh   String
  contentJa   String   @default("")
  contentAr   String   @default("")
  excerpt     String?
  image       String?
  source      String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model CaseStudy {
  id          String   @id @default(uuid())
  slug        String   @unique
  titleEn     String
  titleZh     String
  clientName  String
  clientLogo  String?
  country     String
  image       String?
  contentEn   String
  contentZh   String
  rating      Int      @default(5)
  createdAt   DateTime @default(now())
}

model Certificate {
  id          String   @id @default(uuid())
  name        String
  issuer      String
  image       String?
  pdfUrl      String?
  validUntil  DateTime?
  createdAt   DateTime @default(now())
}

// ─── Admin & Reports ────────────────────────────────────────
model AdminUser {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        String   @default("admin") // admin, expert
  avatar      String?
  bio         String?
  title       String?
  createdAt   DateTime @default(now())
  expertReviews ExpertReview[]
}

model ExpertReview {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  expertId    String
  expert      AdminUser @relation(fields: [expertId], references: [id])
  content     String
  rating      Int       @default(5)
  createdAt   DateTime  @default(now())
}

model Report {
  id          String   @id @default(uuid())
  type        String   // daily, weekly, monthly
  dateFrom    DateTime
  dateTo      DateTime
  dataJson    String   // JSON report data
  emailSent   Boolean  @default(false)
  sentTo      String?
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id          String   @id @default(uuid())
  name        String
  email       String
  company     String?
  phone       String?
  subject     String?
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model SiteSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  updatedAt   DateTime @updatedAt
}

model NewsletterSubscriber {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String?
  source      String?  // footer, popup, manual
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}
