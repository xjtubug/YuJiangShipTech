generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Product Catalog ────────────────────────────────────────
model Category {
  id          String    @id @default(uuid())
  slug        String    @unique
  nameEn      String
  nameZh      String
  nameJa      String
  nameAr      String
  image       String?
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id              String    @id @default(uuid())
  slug            String    @unique
  sku             String    @unique
  nameEn          String
  nameZh          String
  nameJa          String
  nameAr          String
  descEn          String    @db.Text
  descZh          String    @db.Text
  descJa          String    @db.Text
  descAr          String    @db.Text
  specsJson       String    @default("{}") @db.VarChar(5000)
  priceCny        Float     @default(0)    // 人民币基准价格
  priceUsd        Float     @default(0)
  moq             Int       @default(1)
  leadTimeDays    Int       @default(30)
  images          String    @default("[]") @db.VarChar(2000)
  videoUrl        String?
  pdfUrl          String?
  featured        Boolean   @default(false)
  published       Boolean   @default(true)
  status          String    @default("published") // draft, published, archived
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])
  reviews         Review[]
  expertReviews   ExpertReview[]
  customerComments CustomerComment[]
  inquiryItems    InquiryItem[]
  pageViews       PageView[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([categoryId])
  @@index([status, published])
  @@index([featured])
}

model Review {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  author      String
  company     String?
  country     String?
  rating      Int      @default(5)
  contentEn   String @db.Text
  contentZh   String   @default("")
  avatar      String?
  images      String   @default("[]") @db.VarChar(2000)
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── Customer Comments (商品留言) ─────────────────────────────
model CustomerComment {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  name        String
  email       String
  company     String?
  country     String?
  content     String
  images      String   @default("[]") @db.VarChar(2000)
  rating      Int      @default(5)
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── B2B Inquiry System ─────────────────────────────────────
model Inquiry {
  id              String        @id @default(uuid())
  inquiryNumber   String        @unique
  companyName     String
  contactName     String
  email           String
  phone           String?
  country         String?
  message         String?
  techRequirements String? @db.Text
  attachmentUrl   String?
  status          String        @default("new") // new, processing, quoted, closed
  source          String?       // page URL
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  items           InquiryItem[]
  followUps       InquiryFollowUp[]
  quotations      Quotation[]
  visitorId       String?
  visitor         Visitor?      @relation(fields: [visitorId], references: [id])
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model InquiryItem {
  id          String   @id @default(uuid())
  inquiryId   String
  inquiry     Inquiry  @relation(fields: [inquiryId], references: [id])
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  productName String
  quantity    Int      @default(1)
  unit        String   @default("pcs")
  specs       String?
  createdAt   DateTime @default(now())
}

// ─── Inquiry Follow-up (询价跟进) ────────────────────────────
model InquiryFollowUp {
  id          String   @id @default(uuid())
  inquiryId   String
  inquiry     Inquiry  @relation(fields: [inquiryId], references: [id])
  action      String   // call, email, meeting, note, quote_sent
  content     String
  createdBy   String   @default("admin")
  createdAt   DateTime @default(now())
}

// ─── Visitor Tracking & Lead Scoring ────────────────────────
model Visitor {
  id            String      @id @default(uuid())
  ip            String
  country       String?
  region        String?
  city          String?
  userAgent     String?
  browser       String?
  os            String?
  device        String?
  language      String?
  referrer      String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  leadScore     Int         @default(0)
  isHighValue   Boolean     @default(false)
  firstVisit    DateTime    @default(now())
  lastVisit     DateTime    @default(now())
  visitCount    Int         @default(1)
  pageViews     PageView[]
  inquiries     Inquiry[]

  @@index([ip])
  @@index([leadScore])
  @@index([isHighValue])
}

model PageView {
  id          String   @id @default(uuid())
  visitorId   String
  visitor     Visitor  @relation(fields: [visitorId], references: [id])
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  path        String
  title       String?
  duration    Int      @default(0) // seconds
  createdAt   DateTime @default(now())

  @@index([visitorId])
  @@index([productId])
  @@index([createdAt])
}

// ─── CMS Content ────────────────────────────────────────────
model News {
  id            String   @id @default(uuid())
  slug          String   @unique
  category      String   @default("company") // industry, company
  titleEn       String
  titleZh       String
  titleJa       String   @default("")
  titleAr       String   @default("")
  contentEn     String   @db.Text
  contentZh     String   @db.Text
  contentJa     String   @default("")
  contentAr     String   @default("")
  excerpt       String?
  image         String?
  images        String   @default("[]") @db.VarChar(5000) // carousel images
  source        String?
  sourceUrl     String?
  autoGenerated Boolean  @default(false)
  published     Boolean  @default(true)
  publishedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([category])
  @@index([published, publishedAt])
}

model CaseStudy {
  id          String   @id @default(uuid())
  slug        String   @unique
  titleEn     String
  titleZh     String
  clientName  String
  clientLogo  String?
  country     String
  image       String?
  images      String   @default("[]") @db.VarChar(5000)
  videoUrl    String?
  latitude    Float?
  longitude   Float?
  locationName String?
  contentEn   String @db.Text
  contentZh   String @db.Text
  rating      Int      @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Certificate {
  id          String   @id @default(uuid())
  name        String
  issuer      String
  image       String?
  pdfUrl      String?
  validUntil  DateTime?
  createdAt   DateTime @default(now())
}

// ─── Quotation System (报价系统) ─────────────────────────────
model Quotation {
  id              String   @id @default(uuid())
  quotationNumber String   @unique
  inquiryId       String?
  inquiry         Inquiry? @relation(fields: [inquiryId], references: [id])
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  contactName     String
  companyName     String
  email           String
  phone           String?
  country         String?
  currency        String   @default("USD")
  subtotal        Float    @default(0)
  discount        Float    @default(0)
  tax             Float    @default(0)
  shippingCost    Float    @default(0)
  grandTotal      Float    @default(0)
  validDays       Int      @default(30)
  paymentTerms    String   @default("T/T 30% deposit, 70% before shipment") @db.VarChar(500)
  deliveryTerms   String?  @db.VarChar(500)
  notes           String?  @db.Text
  status          String   @default("draft") // draft, pending_approval, approved, sent, accepted, rejected, expired
  approvedBy      String?
  approvedAt      DateTime?
  sentAt          DateTime?
  pdfUrl          String?
  attachments     String   @default("[]") @db.VarChar(5000)
  items           QuotationItem[]
  orders          Order[]
  createdBy       String   @default("admin")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model QuotationItem {
  id            String    @id @default(uuid())
  quotationId   String
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId     String?
  productName   String
  description   String?   @db.Text
  sku           String?
  quantity      Int       @default(1)
  unit          String    @default("pcs")
  unitPrice     Float     @default(0)
  total         Float     @default(0)
  sortOrder     Int       @default(0)
}

// ─── Order Management (订单管理) ─────────────────────────────
model Order {
  id              String   @id @default(uuid())
  orderNumber     String   @unique
  quotationId     String?
  quotation       Quotation? @relation(fields: [quotationId], references: [id])
  inquiryId       String?
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  contactName     String
  companyName     String
  email           String
  phone           String?
  country         String?
  currency        String   @default("USD")
  subtotal        Float    @default(0)
  discount        Float    @default(0)
  tax             Float    @default(0)
  shippingCost    Float    @default(0)
  grandTotal      Float    @default(0)
  paymentTerms    String?  @db.VarChar(500)
  deliveryTerms   String?  @db.VarChar(500)
  shippingMethod  String?  // dhl, fedex, sea_freight, air_freight
  trackingNumber  String?
  trackingUrl     String?
  shippingAddress String?  @db.Text
  notes           String?  @db.Text
  status          String   @default("confirmed") // confirmed, in_production, ready_to_ship, shipped, in_transit, delivered, completed, cancelled
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  createdBy       String   @default("admin")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model OrderItem {
  id            String @id @default(uuid())
  orderId       String
  order         Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String?
  productName   String
  description   String? @db.Text
  sku           String?
  quantity      Int    @default(1)
  unit          String @default("pcs")
  unitPrice     Float  @default(0)
  total         Float  @default(0)
  sortOrder     Int    @default(0)
}

model OrderStatusHistory {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  String?
  toStatus    String
  note        String?  @db.Text
  createdBy   String   @default("admin")
  createdAt   DateTime @default(now())
}

// ─── Email Marketing (邮件营销) ──────────────────────────────
model EmailTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  subject     String
  body        String   @db.Text
  type        String   // welcome, inquiry_followup, promotion, holiday, custom
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailCampaign {
  id          String   @id @default(uuid())
  name        String
  templateId  String?
  subject     String
  body        String   @db.Text
  type        String   // manual, auto_welcome, auto_followup, auto_holiday
  status      String   @default("draft") // draft, scheduled, sending, sent, cancelled
  scheduledAt DateTime?
  sentAt      DateTime?
  totalSent   Int      @default(0)
  totalOpened Int      @default(0)
  totalClicked Int     @default(0)
  targetTags  String   @default("[]") @db.VarChar(2000)
  createdBy   String   @default("admin")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailLog {
  id          String   @id @default(uuid())
  campaignId  String?
  to          String
  subject     String
  status      String   @default("sent") // sent, delivered, opened, clicked, bounced, failed
  sentAt      DateTime @default(now())

  @@index([campaignId])
  @@index([sentAt])
}

// ─── Media Management (媒体管理) ─────────────────────────────
model MediaFile {
  id          String   @id @default(uuid())
  filename    String
  originalName String
  url         String
  mimeType    String
  size        Int
  width       Int?
  height      Int?
  category    String   @default("general") // product, news, certificate, avatar, document
  alt         String?
  createdBy   String   @default("admin")
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([createdAt])
}

// ─── About Us Content (关于我们) ─────────────────────────────
model AboutContent {
  id          String   @id @default(uuid())
  section     String   @unique // intro, factory, team, location, pdf
  titleEn     String   @default("")
  titleZh     String   @default("")
  contentEn   String   @default("") @db.Text
  contentZh   String   @default("") @db.Text
  images      String   @default("[]") @db.VarChar(5000)
  videoUrl    String?
  pdfUrl      String?
  extraJson   String   @default("{}") @db.Text
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id          String   @id @default(uuid())
  nameEn      String
  nameZh      String
  titleEn     String   @default("")
  titleZh     String   @default("")
  avatar      String?
  bio         String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

// ─── Admin & Reports ────────────────────────────────────────
model AdminUser {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        String   @default("admin") // admin, expert
  avatar      String?
  bio         String?
  title       String?
  active      Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expertReviews ExpertReview[]
}

model ExpertReview {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  expertId    String
  expert      AdminUser @relation(fields: [expertId], references: [id])
  content     String
  rating      Int       @default(5)
  images      String    @default("[]") // JSON array of image URLs
  videoUrl    String?
  createdAt   DateTime  @default(now())
}

model Report {
  id          String   @id @default(uuid())
  type        String   // daily, weekly, monthly, quarterly, yearly
  dateFrom    DateTime
  dateTo      DateTime
  dataJson    String   @db.LongText // JSON report data
  emailSent   Boolean  @default(false)
  sentTo      String?
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
}

model ReportSchedule {
  id          String   @id @default(uuid())
  enabled     Boolean  @default(false)
  frequency   String   // daily, weekly, monthly, quarterly, yearly
  email       String
  lastSentAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id            String   @id @default(uuid())
  name          String
  email         String
  company       String?
  phone         String?
  subject       String?
  message       String
  attachmentUrl String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model SiteSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  updatedAt   DateTime @updatedAt
}

model NewsletterSubscriber {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String?
  source      String?  // footer, popup, manual
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── Customer CRM ───────────────────────────────────────────
model Customer {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String
  company     String?
  phone       String?
  country     String?
  tags        String   @default("[]") @db.VarChar(2000)
  source      String   @default("inquiry") // inquiry, manual, newsletter
  notes       String?
  inquiries   Inquiry[]
  quotations  Quotation[]
  orders      Order[]
  followUps   CustomerFollowUp[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CustomerFollowUp {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  action      String   // call, email, meeting, note, order
  content     String
  createdBy   String   @default("admin")
  createdAt   DateTime @default(now())
}

// ─── Notification System (通知系统) ──────────────────────────
model Notification {
  id          String   @id @default(uuid())
  type        String   // new_inquiry, new_visitor, new_comment, system
  title       String
  message     String
  link        String?  // URL to related resource
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([read, createdAt])
}
